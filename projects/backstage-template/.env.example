# .env — your private credentials
#
# This file is like a password manager for the app.
# NEVER share this file or commit it to GitHub — it's listed in .gitignore for that reason.
#
# HOW TO USE:
#   1. Copy this file: copy .env.example .env  (Windows) / cp .env.example .env  (Mac/Linux)
#   2. Fill in each value below with your real information
#   3. Save it — the app reads it automatically when you run any command


# --- PiShock credentials ---
# These let the app connect to your PiShock account and fire shocks.
# Find them at: pishock.com → log in → Account Settings → API

PISHOCK_USERNAME=your_pishock_username
PISHOCK_API_KEY=your_api_key_here

# The share code is specific to a single shocker device.
# How to get it: open the PiShock app → tap your shocker → tap SHARE → copy the code
PISHOCK_SHARE_CODE=your_share_code_here


# --- Railway server ---
# After you deploy server/ to Railway (see docs/deployment.md),
# paste your Railway URL here. It looks like: https://myapp.up.railway.app

RAILWAY_URL=https://yourapp.railway.app

# ARM_SECRET is a password that proves to the Railway server that YOU are the one
# arming the shock button (not some random person who found the URL).
#
# Generate a random value:  python -c "import secrets; print(secrets.token_urlsafe(32))"
# Use the same value here AND in Railway's environment variables.
ARM_SECRET=change_me_to_a_random_secret


# --- OBS ---
# OBS overlay settings go in config.toml, not here.
# (OBS doesn't use credentials — it's just a local connection on your machine.)
